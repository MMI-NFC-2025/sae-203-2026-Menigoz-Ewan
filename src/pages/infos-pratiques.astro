---
// IMPORTATION
// Uniquement le Layout de base, page 100% statique
import Layout from "../layouts/Layout.astro";
---

<Layout title="Infos Pratiques - La Fanfa'Comtoise">
    <main class="w-full bg-[#FAFAFA]">
        <section
            class="bg-[#F6F3E9] py-24 md:py-32 px-6 text-center flex flex-col items-center justify-center"
        >
            <h1 class="text-5xl md:text-[4rem] font-extrabold text-[#111] mb-6">
                Infos Pratiques
            </h1>
            <p class="text-xl text-[#444] max-w-[750px] mx-auto font-medium">
                Tout ce qu'il faut savoir pour profiter pleinement du festival
            </p>
        </section>

        <section class="max-w-[1100px] mx-auto my-20 px-6">
            <div class="flex items-center gap-5 mb-10">
                <img
                    src="/vector_prices_infos.svg"
                    alt="Tarifs"
                    class="w-10 h-10 object-contain"
                />
                <h2 class="text-3xl md:text-4xl font-extrabold text-[#111]">
                    Tarifs
                </h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div
                    class="bg-white p-10 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] border border-gray-100 flex flex-col gap-4"
                >
                    <h3 class="text-2xl font-extrabold text-[#F29C1F]">
                        Festival 100% Gratuit !
                    </h3>
                    <p class="text-[#555] leading-relaxed text-lg">
                        L'entrée au festival est totalement gratuite et ouverte
                        à tous. Aucune réservation nécessaire.
                    </p>
                </div>

                <div
                    class="bg-white p-10 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] border border-gray-100 flex flex-col gap-4"
                >
                    <h3 class="text-2xl font-extrabold text-[#111] mb-2">
                        Restauration & Boissons
                    </h3>
                    <ul
                        class="flex flex-col gap-3 text-[#555] text-lg list-disc pl-5 m-0"
                    >
                        <li>
                            Caution gobelet réutilisable : 1€ (remboursée lors
                            du retour)
                        </li>
                        <li>Boissons : 2€ - 5€</li>
                        <li>Restauration locale : 5€ - 12€</li>
                        <li>Stands de producteurs bio et locaux</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="max-w-[1100px] mx-auto my-20 px-6">
            <div class="flex items-center gap-5 mb-10">
                <img
                    src="/vector_hebergement_infos.svg"
                    alt="Hébergements"
                    class="w-10 h-10 object-contain"
                />
                <h2 class="text-3xl md:text-4xl font-extrabold text-[#111]">
                    Hébergements
                </h2>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
                <div
                    class="bg-white p-10 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] border border-gray-100"
                >
                    <h3 class="text-2xl font-extrabold mb-8 text-[#111]">
                        Hôtels
                    </h3>
                    <div class="flex flex-col gap-6">
                        <div
                            class="border-b border-gray-100 pb-4 last:border-0 last:pb-0"
                        >
                            <h4 class="text-xl font-bold text-[#F29C1F] mb-1">
                                Hôtel de la Balance
                            </h4>
                            <p class="text-[#555] leading-relaxed">
                                40 Rue de Belfort, Montbéliard<br />À 5 min à
                                pied du festival
                            </p>
                        </div>
                        <div
                            class="border-b border-gray-100 pb-4 last:border-0 last:pb-0"
                        >
                            <h4 class="text-xl font-bold text-[#F29C1F] mb-1">
                                Ibis Montbéliard
                            </h4>
                            <p class="text-[#555] leading-relaxed">
                                5 Rue Georges Pompidou<br />À 10 min à pied du
                                festival
                            </p>
                        </div>
                        <div
                            class="border-b border-gray-100 pb-4 last:border-0 last:pb-0"
                        >
                            <h4 class="text-xl font-bold text-[#F29C1F] mb-1">
                                B&B Hotel
                            </h4>
                            <p class="text-[#555] leading-relaxed">
                                25C 59 Rue des Gourties<br />À 15 min en bus
                            </p>
                        </div>
                    </div>
                </div>

                <div
                    class="bg-white p-10 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] border border-gray-100"
                >
                    <h3 class="text-2xl font-extrabold mb-6 text-[#111]">
                        Chambres d'hôtes
                    </h3>
                    <p class="text-[#555] text-lg leading-relaxed">
                        Plusieurs options d'hébergement chez l'habitant sont
                        disponibles à proximité du festival. Contactez-nous pour
                        plus d'informations.
                    </p>
                </div>
            </div>
        </section>

        <section class="max-w-[1100px] mx-auto my-20 px-6">
            <div class="flex items-center gap-5 mb-10">
                <img
                    src="/vector_transport_infos.svg"
                    alt="Accès & Transport"
                    class="w-10 h-10 object-contain"
                />
                <h2 class="text-3xl md:text-4xl font-extrabold text-[#111]">
                    Accès & Transport
                </h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div
                    class="bg-white p-8 rounded-[15px] shadow-sm border border-gray-100"
                >
                    <div class="flex items-center gap-3 mb-6">
                        <img
                            src="/vector_train_infos.svg"
                            alt="Train"
                            class="w-7 h-7 object-contain"
                        />
                        <h3 class="text-xl font-bold text-[#111]">En train</h3>
                    </div>
                    <div class="text-[#555] leading-relaxed">
                        <p class="mb-3">
                            <strong>Gare de Montbéliard :</strong><br />À 15 min
                            à pied.
                        </p>
                        <ul class="list-disc pl-5">
                            <li>Paris : 2h50</li>
                            <li>Lyon : 3h</li>
                            <li>Besançon : 45 min</li>
                        </ul>
                    </div>
                </div>

                <div
                    class="bg-white p-8 rounded-[15px] shadow-sm border border-gray-100"
                >
                    <div class="flex items-center gap-3 mb-6">
                        <img
                            src="/vector_car_infos.svg"
                            alt="Voiture"
                            class="w-7 h-7 object-contain"
                        />
                        <h3 class="text-xl font-bold text-[#111]">
                            En voiture
                        </h3>
                    </div>
                    <div class="text-[#555] leading-relaxed">
                        <p class="mb-4"><strong>Accès par l'A36</strong></p>
                        <p class="mb-2"><strong>Parkings gratuits :</strong></p>
                        <ul class="list-disc pl-5 mb-6 text-sm">
                            <li>Champ-de-Foire (10 min)</li>
                            <li>Gare (15 min)</li>
                            <li>Halles (5 min)</li>
                        </ul>
                    </div>
                </div>

                <div
                    class="bg-white p-8 rounded-[15px] shadow-sm border border-gray-100"
                >
                    <div class="flex items-center gap-3 mb-6">
                        <img
                            src="/vector_smooth_transport_infos.svg"
                            alt="Transport doux"
                            class="w-7 h-7 object-contain"
                        />
                        <h3 class="text-xl font-bold text-[#111]">
                            Transport doux
                        </h3>
                    </div>
                    <div class="text-[#555] leading-relaxed">
                        <ul class="flex flex-col gap-4 list-disc pl-5 text-sm">
                            <li><strong>Vélo :</strong> Pistes sécurisées.</li>
                            <li>
                                <strong>Bus :</strong> Réseau CTPM, arrêt "Place Saint-Martin".
                            </li>
                            <li>
                                <strong>Véli-Go :</strong> Stations à proximité.
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <section class="max-w-[900px] mx-auto my-24 px-6">
            <div class="flex items-center gap-5 mb-10 justify-center">
                <img
                    src="/vector_questions_infos.svg"
                    alt="Questions"
                    class="w-10 h-10 object-contain"
                />
                <h2 class="text-3xl md:text-4xl font-extrabold text-[#111]">
                    Questions fréquentes
                </h2>
            </div>

            <div class="flex flex-col gap-4">
                {
                    // Un tableau contenant les questions et les réponses
                    [
                        {
                            q: "Le festival est-il vraiment gratuit ?",
                            a: "Oui, l'entrée au festival est totalement gratuite. Aucune réservation n'est nécessaire. Seules les consommations à titre optionnel (boissons, restauration) sont payantes.",
                        },
                        {
                            q: "Comment le festival respecte-t-il l'environnement ?",
                            a: "La Fanfa'Comtoise s'engage pour l'écoresponsabilité : gestion des déchets, gobelets réutilisables, restauration bio et locale, transport doux encouragé.",
                        },
                        {
                            q: "Peut-on venir avec des enfants ?",
                            a: "Bien sûr ! Le festival est familial et accueille les enfants de tous les âges. Des zones d'ombre et de repos sont aménagées.",
                        },
                        {
                            q: "Où peut-on se restaurer ?",
                            a: "Des stands de restauration locale et bio sont présents à proximité de chaque scène.",
                        },
                        {
                            q: "Le festival est-il accessible aux PMR ?",
                            a: "Oui, toutes les scènes sont accessibles PMR. Des zones de stationnement réservées sont disponibles.",
                        },
                    ].map((faq) => (
                        // La balise <details> gère l'ouverture/fermeture sans JavaScript
                        <details class="group bg-white rounded-[15px] shadow-sm border border-gray-100 overflow-hidden transition-all">
                            <summary class="flex justify-between items-center font-bold text-lg text-[#111] p-6 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                                <span>{faq.q}</span>
                                <img
                                    src="/vector_question_arrow_infos.svg"
                                    alt="Ouvrir"
                                    class="w-5 h-5 transition-transform duration-300 group-open:rotate-180"
                                />
                            </summary>

                            <div class="px-6 pb-6 text-[#555] leading-relaxed">
                                <p>{faq.a}</p>
                            </div>
                        </details>
                    ))
                }
            </div>
        </section>

        <section
            class="bg-[#F29C1F] py-20 px-6 text-center flex flex-col items-center justify-center"
        >
            <h2 class="text-4xl font-black text-white mb-4 uppercase">
                Une question ?
            </h2>
            <p class="text-xl text-white/90 mb-10 max-w-[600px] mx-auto">
                Vous ne trouvez pas la réponse à votre question ? N'hésitez pas
                à nous contacter !
            </p>
            <a
                href="/contact"
                class="inline-block bg-white text-[#F29C1F] px-10 py-4 rounded-full font-extrabold text-lg transition-transform hover:-translate-y-1 shadow-lg"
            >
                Nous contacter
            </a>
        </section>
    </main>
</Layout>
