---
import Layout from "../layouts/Layout.astro";
---

<Layout title="La Fanfa'Comtoise - Accueil">
	<main class="w-full">
		<section
			class="relative w-full h-[80vh] min-h-[500px] flex items-center justify-center overflow-hidden"
		>
			<img
				src="/hero_homepage.avif"
				alt="Hero du site"
				class="absolute inset-0 w-full h-full object-cover z-0"
			/>
			<div class="absolute inset-0 bg-black/30 z-10"></div>

			<div
				class="relative z-20 flex flex-col items-center gap-5 text-center px-6 w-full font-title"
			>
				<h1
					class="text-white text-4xl md:text-[4rem] font-black leading-[1.1] drop-shadow-2xl tracking-tight"
				>
					JAZZ, FANFARES & MUSIQUES<br class="hidden md:block" /> DE RUES
				</h1>

				<div class="flex flex-wrap gap-4 justify-center font-sans">
					<div
						class="bg-white text-black px-6 py-2.5 rounded-full flex items-center gap-2.5 font-bold text-sm md:text-base shadow-lg"
					>
						<img
							src="/vector_date_hero_homepage.svg"
							alt="date"
							class="w-5 h-5"
						/>
						<span>27-29 juin 2025</span>
					</div>
					<div
						class="bg-white text-black px-6 py-2.5 rounded-full flex items-center gap-2.5 font-bold text-sm md:text-base shadow-lg"
					>
						<img
							src="/vector_location_hero_homepage.svg"
							alt="lieu"
							class="w-5 h-5"
						/>
						<span>Montbéliard</span>
					</div>
				</div>

				<div class="flex flex-wrap gap-4 justify-center mt-4 font-sans">
					<a
						href="/programme"
						class="bg-[var(--color-primary)] text-white px-7 py-3 rounded-full flex items-center gap-2.5 font-bold text-base shadow-lg hover:-translate-y-1 transition-all"
					>
						<img
							src="/vector_discover_hero_homepage.svg"
							alt="musique"
							class="w-5 h-5 brightness-0 invert"
						/> Découvrir le programme
					</a>
					<a
						href="#billetterie"
						class="bg-[var(--color-secondary)] text-black px-7 py-3 rounded-full flex items-center gap-2.5 font-bold text-base shadow-lg hover:-translate-y-1 transition-all"
					>
						<img
							src="/vector_tickets_hero_homepage.svg"
							alt="billetterie"
							class="w-5 h-5"
						/> Billetterie
					</a>
				</div>

				<div
					class="bg-[var(--color-accent)] text-white px-6 py-2.5 rounded-full flex items-center gap-2.5 font-bold text-sm shadow-lg mt-4 font-sans"
				>
					<img
						src="/vector_free_eco_hero_homepage.svg"
						alt="eco"
						class="w-5 h-5 brightness-0 invert"
					/> GRATUIT & ÉCO
				</div>
			</div>
		</section>

		<section class="bg-[var(--color-bg-warm)] py-20 px-6">
			<div
				class="max-w-[1200px] mx-auto flex flex-col items-center gap-12 font-title"
			>
				<h2
					class="text-3xl md:text-4xl font-black text-black text-center"
				>
					Le Festival en Chiffres
				</h2>

				<div
					class="w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 font-sans"
				>
					{
						[
							{
								icon: "/vector_artist_homepage.svg",
								title: "6 Artistes",
								desc: "Jazz, fanfares et musiques de rue",
							},
							{
								icon: "/vector_eco_homepage.svg",
								title: "100% Éco",
								desc: "Festival écoresponsable et local",
							},
							{
								icon: "/vector_free_homepage.svg",
								title: "Gratuit",
								desc: "Ouvert et accessible à tous",
							},
							{
								icon: "/vector_scenes_homepage.svg",
								title: "3 Scènes",
								desc: "Dans le centre-ville historique",
							},
						].map((stat) => (
							<article class="bg-white rounded-xl p-10 text-center shadow-sm flex flex-col items-center gap-3 hover:-translate-y-1 transition-transform duration-300 border border-gray-100">
								<div class="w-9 h-9 flex items-center justify-center mb-2">
									<img
										src={stat.icon}
										alt={stat.title}
										class="w-full h-full object-contain"
									/>
								</div>
								<h3 class="text-lg font-bold text-black">
									{stat.title}
								</h3>
								<p class="text-sm text-gray-600 leading-relaxed font-medium">
									{stat.desc}
								</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section
			class="bg-white py-20 w-full overflow-hidden border-t border-gray-50"
		>
			<h2
				class="text-3xl md:text-4xl font-black text-black text-center mb-12 font-title"
			>
				Nos partenaires
			</h2>

			<div class="relative w-full overflow-hidden group">
				<div class="flex w-max animate-marquee group-hover:pause">
					{
						[1, 2].map(() => (
							<div class="flex gap-6 pr-6">
								{[
									"/partner_pdma.avif",
									"/partner_rbfc.avif",
									"/partner_doubs.avif",
									"/partner_poudriere.avif",
									"/partner_molocco.avif",
									"/partner_airbnb.avif",
									"/partner_creditagricole.avif",
								].map((src) => (
									<div class="w-48 h-24 bg-white border border-gray-100 rounded-lg flex items-center justify-center p-6 shadow-sm hover:scale-105 transition-transform">
										<img
											src={src}
											alt="Partenaire"
											class="max-w-full max-h-full object-contain"
										/>
									</div>
								))}
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section
			class="bg-[var(--color-primary)] py-20 px-6 text-center flex justify-center"
		>
			<div
				class="max-w-[800px] flex flex-col items-center gap-6 text-white font-sans"
			>
				<h2 class="text-4xl font-black text-black font-title uppercase">
					Préparez votre venue
				</h2>
				<p
					class="text-lg opacity-100 font-medium text-white max-w-[650px]"
				>
					Téléchargez le programme complet et consultez toutes les
					informations pratiques pour profiter pleinement du festival
				</p>
				<div class="flex flex-wrap gap-6 justify-center mt-6">
					<a
						href="/programme.pdf"
						class="bg-white text-[var(--color-primary)] px-8 py-3 rounded-full font-bold text-base shadow-lg hover:-translate-y-1 transition-transform flex items-center gap-2.5"
					>
						<img
							src="/vector_download_homepage.svg"
							alt="télécharger"
							class="w-5 h-5"
						/> Télécharger le programme
					</a>
					<a
						href="/contact"
						class="bg-transparent text-white border-2 border-white px-8 py-3 rounded-full font-bold text-base hover:bg-white hover:text-[var(--color-primary)] transition-all"
					>
						Nous contacter
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.no-scrollbar::-webkit-scrollbar {
		display: none;
	}
	.no-scrollbar {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}

	.animate-marquee {
		animation: marquee 30s linear infinite;
	}
	@keyframes marquee {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}
	.pause {
		animation-play-state: paused;
	}
</style>

<script>
	const track = document.querySelector(".carousel__container");
	const nextBtn = document.querySelector(".carousel__btn--next");
	const prevBtn = document.querySelector(".carousel__btn--prev");

	if (track && nextBtn && prevBtn) {
		const scrollAmount = () =>
			track.querySelector(".carousel__slide")?.clientWidth + 24 || 300;
		nextBtn.addEventListener("click", () =>
			track.scrollBy({ left: scrollAmount(), behavior: "smooth" }),
		);
		prevBtn.addEventListener("click", () =>
			track.scrollBy({ left: -scrollAmount(), behavior: "smooth" }),
		);

		let isDown = false,
			startX,
			scrollLeft;
		track.addEventListener("mousedown", (e) => {
			isDown = true;
			startX =
				(e as MouseEvent).pageX - (track as HTMLElement).offsetLeft;
			scrollLeft = track.scrollLeft;
		});
		track.addEventListener("mouseleave", () => (isDown = false));
		track.addEventListener("mouseup", () => (isDown = false));
		track.addEventListener("mousemove", (e) => {
			if (!isDown) return;
			e.preventDefault();
			const x =
				(e as MouseEvent).pageX - (track as HTMLElement).offsetLeft;
			const walk = (x - startX) * 2;
			track.scrollLeft = scrollLeft - walk;
		});
	}
</script>
