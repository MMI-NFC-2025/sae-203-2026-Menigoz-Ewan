---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <section class="error-404">
        <div class="error-404__container">
            <div class="error-404__content">
                <h1 class="error-404__title">404</h1>
                <h2 class="error-404__subtitle">Oups ! Page non trouvée</h2>
                <p class="error-404__description">
                    Désolé, la page que vous recherchez n'existe pas ou a été
                    déplacée. Il semble que vous ayez pris un mauvais tournant
                    lors de votre visite au festival !
                </p>

                <div class="error-404__actions">
                    <a href="/" class="error-404__btn error-404__btn--primary"
                        >Retourner à l'accueil</a
                    >
                    <a
                        href="/contact"
                        class="error-404__btn error-404__btn--secondary"
                        >Nous contacter</a
                    >
                </div>

                <h3 class="error-404__suggestions-title">
                    Vous cherchiez peut-être :
                </h3>
                <ul class="error-404__suggestions-list">
                    <li><a href="/festival">Le Festival</a></li>
                    <li><a href="/programme">Programme</a></li>
                    <li><a href="/artistes">Artistes</a></li>
                    <li><a href="/scenes">Les Scènes</a></li>
                    <li><a href="/infos">Infos Pratiques</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
            </div>

            <div class="error-404__illustration">
                <div class="error-404__illustration-icon">
                    <img src="/vector_music.svg" alt="Note de musique" />
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .error-404 {
        min-height: calc(100vh - 80px - 120px);
        background-color: #f6f3e9;
        display: flex;
        align-items: center;
        padding: 3rem 1.5rem;
    }

    .error-404__container {
        max-width: 960px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
        gap: 2.5rem;
        align-items: center;
    }

    .error-404__content {
        background-color: #ffffff;
        border-radius: 18px;
        padding: 2rem 1.8rem;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
    }

    .error-404__title {
        margin: 0 0 0.3rem;
        font-size: 3rem;
        font-weight: 800;
        color: #f29c1f;
    }

    .error-404__subtitle {
        margin: 0 0 0.8rem;
        font-size: 1.3rem;
        font-weight: 800;
        color: #333333;
    }

    .error-404__description {
        margin: 0 0 1.2rem;
        font-size: 0.95rem;
        color: #555555;
        line-height: 1.7;
    }

    .error-404__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-bottom: 1.3rem;
    }

    .error-404__btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.7rem 1.7rem;
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        border: 2px solid transparent;
    }

    .error-404__btn--primary {
        background-color: #f29c1f;
        color: #ffffff;
    }

    .error-404__btn--secondary {
        background-color: #ffffff;
        color: #f29c1f;
        border-color: #f29c1f;
    }

    .error-404__suggestions-title {
        margin: 0 0 0.4rem;
        font-size: 0.95rem;
        font-weight: 700;
        color: #333333;
    }

    .error-404__suggestions-list {
        margin: 0;
        padding-left: 1.1rem;
        font-size: 0.9rem;
    }

    .error-404__suggestions-list a {
        color: #f29c1f;
        text-decoration: none;
    }

    .error-404__suggestions-list a:hover {
        text-decoration: underline;
    }

    .error-404__illustration {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .error-404__illustration-icon {
        width: 120px;
        height: 120px;
        padding: 1.5rem;
        border-radius: 50%;
        background-color: #8fd26a;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .error-404__illustration-icon img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    @media (max-width: 800px) {
        .error-404 {
            padding: 2.5rem 1.5rem 3rem;
        }

        .error-404__container {
            grid-template-columns: 1fr;
        }

        .error-404__content {
            order: 1;
        }

        .error-404__illustration {
            order: 0;
        }

        .error-404__title {
            font-size: 2.4rem;
        }
    }
</style>
