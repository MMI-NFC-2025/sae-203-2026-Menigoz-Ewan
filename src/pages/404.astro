---
// IMPORTATION DU LAYOUT
// On utilise la même structure de base (Header, Footer, CSS global) que le reste du site
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page non trouvée - La Fanfa'Comtoise">
    <main class="w-full">
        <section
            class="min-h-screen bg-[var(--color-bg-warm)] flex items-center justify-center p-6 md:p-12 font-sans"
        >
            <div
                class="max-w-5xl w-full flex flex-col md:flex-row items-center justify-between gap-12"
            >
                <div
                    class="bg-white rounded-2xl p-8 md:p-10 shadow-lg w-full md:w-[55%] flex flex-col border border-gray-100"
                >
                    <h1
                        class="text-6xl font-black text-[var(--color-primary)] mb-2 font-title uppercase tracking-tighter"
                    >
                        404
                    </h1>
                    <h2 class="text-2xl font-bold text-black mb-4 font-title">
                        Oups ! Page non trouvée
                    </h2>

                    <p class="text-gray-600 mb-6 leading-relaxed font-medium">
                        Désolé, la page que vous recherchez n'existe pas ou a
                        été déplacée. Il semble que vous ayez pris un mauvais
                        tournant lors de votre visite au festival !
                    </p>

                    <div class="flex flex-wrap gap-4 mb-8">
                        <a
                            href="/"
                            class="px-6 py-2.5 bg-[var(--color-primary)] text-white font-bold rounded-full hover:brightness-110 transition-all shadow-md font-title uppercase tracking-wide text-sm"
                        >
                            Retourner à l'accueil
                        </a>
                        <a
                            href="/contact"
                            class="px-6 py-2.5 bg-white text-[var(--color-primary)] border-2 border-[var(--color-primary)] font-bold rounded-full hover:bg-[var(--color-bg-warm)] transition-all font-title uppercase tracking-wide text-sm"
                        >
                            Nous contacter
                        </a>
                    </div>

                    <h3 class="font-bold text-black mb-3 font-title">
                        Vous cherchiez peut-être :
                    </h3>
                    <ul
                        class="list-disc pl-6 text-[var(--color-primary)] space-y-1 font-medium"
                    >
                        <li>
                            <a
                                href="/festival"
                                class="hover:underline text-[var(--color-primary)]"
                                >Le Festival</a>
                        </li>
                        <li>
                            <a
                                href="/programme"
                                class="hover:underline text-[var(--color-primary)]"
                                >Programme</a>
                        </li>
                        <li>
                            <a
                                href="/artistes"
                                class="hover:underline text-[var(--color-primary)]"
                                >Artistes</a>
                        </li>
                        <li>
                            <a
                                href="/scenes"
                                class="hover:underline text-[var(--color-primary)]"
                                >Les Scènes</a>
                        </li>
                        <li>
                            <a
                                href="/infos"
                                class="hover:underline text-[var(--color-primary)]"
                                >Infos Pratiques</a>
                        </li>
                        <li>
                            <a
                                href="/contact"
                                class="hover:underline text-[var(--color-primary)]"
                                >Contact</a>
                        </li>
                    </ul>
                </div>

                <div class="w-full md:w-[45%] flex justify-center">
                    <div
                        class="w-56 h-56 bg-[var(--color-accent)] rounded-full flex items-center justify-center shadow-inner"
                    >
                        <img
                            src="/vector_music.svg"
                            alt="Illustration 404"
                            class="w-24 h-24 object-contain text-[var(--color-accent-soft)] stroke-[var(--color-accent-soft)]"
                        />
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
