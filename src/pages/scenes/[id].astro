---
import Layout from "../../layouts/Layout.astro";
import PocketBase from "pocketbase";

export async function getStaticPaths() {
    const pb = new PocketBase("http://127.0.0.1:8090");

    const records = await pb.collection("scenes").getFullList();

    return records.map((record) => ({
        params: { id: record.id },
        props: { scene: record },
    }));
}

const { scene } = Astro.props;
const pb = new PocketBase("http://127.0.0.1:8090");

const artistes = await pb.collection("artistes").getFullList({
    filter: `scene_id = "${scene.id}"`,
    sort: "+date_passage",
});

const imageUrl = scene.image
    ? `http://127.0.0.1:8090/api/files/${scene.collectionId}/${scene.id}/${scene.image}`
    : "/assets/images/hero-du-site.avif";

const formatteDate = (dateString) => {
    const dateObj = new Date(dateString);
    const formatterJour = new Intl.DateTimeFormat("fr-FR", {
        day: "numeric",
        month: "long",
        year: "numeric",
    });
    const formatterHeure = new Intl.DateTimeFormat("fr-FR", {
        hour: "2-digit",
        minute: "2-digit",
    });
    return `${formatterJour.format(dateObj)} à ${formatterHeure.format(dateObj)}`;
};
---

<Layout title={`${scene.nom} - La Fanfa'Comtoise`}>
    <main
        class="w-full bg-[var(--color-bg-light)] font-sans pb-24 min-h-screen"
    >
        <div
            class="w-full max-w-[1200px] mx-auto px-6 pt-8 pb-4 flex justify-start"
        >
            <a
                href="/scenes"
                class="inline-flex items-center gap-3 text-gray-500 font-bold uppercase tracking-wider hover:text-[var(--color-primary)] transition-colors text-sm md:text-base group whitespace-nowrap"
            >
                <svg
                    class="w-6 h-6 transition-transform group-hover:-translate-x-2"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Retour aux scènes
            </a>
        </div>

        <div class="max-w-[1200px] mx-auto px-6">
            <section
                class="bg-white rounded-[30px] shadow-sm border border-gray-100 overflow-hidden mb-20"
            >
                <div class="w-full h-[400px] relative">
                    <img
                        src={imageUrl}
                        alt={scene.nom}
                        class="w-full h-full object-cover"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex flex-col justify-end p-8 md:p-12"
                    >
                        <span
                            class="inline-block px-6 py-2.5 rounded-full text-base md:text-lg font-black tracking-widest uppercase bg-[var(--color-primary)] text-white mb-6 w-max shadow-md"
                        >
                            La Fanfa'Comtoise
                        </span>
                        <h1
                            class="text-5xl md:text-6xl font-black text-white font-title uppercase tracking-tighter mb-6 leading-none [-webkit-text-stroke:2px_black]"
                        >
                            {scene.nom}
                        </h1>
                        <div
                            class="flex flex-wrap gap-6 text-white font-medium text-lg"
                        >
                            <div class="flex items-center gap-3">
                                <img
                                    src="/vector_place_card_artist.svg"
                                    alt="Localisation"
                                    class="w-6 h-6 filter brightness-0 invert"
                                />
                                <span class="[-webkit-text-stroke:1px_black]"
                                    >{scene.lieu}</span
                                >
                            </div>
                            <div class="flex items-center gap-3">
                                <img
                                    src="/vector_accessibility_festival.svg"
                                    alt="Capacité"
                                    class="w-6 h-6 filter brightness-0 invert"
                                />
                                <span class="[-webkit-text-stroke:1px_black]"
                                    >Capacité : {scene.capacite} personnes</span
                                >
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="mb-20">
                <div class="flex items-center gap-4 mb-8">
                    <span
                        class="w-3 h-3 rounded-full bg-[var(--color-secondary)]"
                    ></span>
                    <h2
                        class="text-3xl md:text-4xl font-black text-black font-title uppercase tracking-tight"
                    >
                        À propos de cette scène
                    </h2>
                </div>
                <div
                    class="bg-white rounded-[30px] p-8 md:p-12 shadow-sm border border-gray-100"
                >
                    <div
                        class="prose max-w-none text-gray-700 text-lg leading-relaxed font-medium"
                        set:html={scene.description ||
                            "Les détails de cette scène seront bientôt ajoutés."}
                    />
                </div>
            </section>

            <section class="mb-20">
                <div class="flex items-center gap-4 mb-8">
                    <span class="w-3 h-3 rounded-full bg-[var(--color-accent)]"
                    ></span>
                    <h2
                        class="text-3xl md:text-4xl font-black text-black font-title uppercase tracking-tight"
                    >
                        Caractéristiques
                    </h2>
                </div>
                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6"
                >
                    <div
                        class="bg-white p-8 rounded-[20px] shadow-sm border border-gray-100 flex flex-col items-start"
                    >
                        <img
                            src="/vector_place_card_artist.svg"
                            alt="Acoustique"
                            class="w-10 h-10 mb-4 text-[var(--color-primary)]"
                        />
                        <h3
                            class="text-xl font-black text-black font-title uppercase tracking-wide mb-3"
                        >
                            Acoustique
                        </h3>
                        <p class="text-gray-600 font-medium leading-relaxed">
                            Acoustique naturelle optimale, parfaite pour les
                            fanfares en plein air.
                        </p>
                    </div>
                    <div
                        class="bg-white p-8 rounded-[20px] shadow-sm border border-gray-100 flex flex-col items-start"
                    >
                        <img
                            src="/vector_accessibility_festival.svg"
                            alt="Accessibilité"
                            class="w-10 h-10 mb-4 text-[var(--color-primary)]"
                        />
                        <h3
                            class="text-xl font-black text-black font-title uppercase tracking-wide mb-3"
                        >
                            Accessibilité
                        </h3>
                        <p class="text-gray-600 font-medium leading-relaxed">
                            Entièrement accessible aux personnes à mobilité
                            réduite (PMR).
                        </p>
                    </div>
                    <div
                        class="bg-white p-8 rounded-[20px] shadow-sm border border-gray-100 flex flex-col items-start"
                    >
                        <img
                            src="/vector_plate_festival.svg"
                            alt="Restauration"
                            class="w-10 h-10 mb-4 text-[var(--color-primary)]"
                        />
                        <h3
                            class="text-xl font-black text-black font-title uppercase tracking-wide mb-3"
                        >
                            Restauration
                        </h3>
                        <p class="text-gray-600 font-medium leading-relaxed">
                            Stands de restauration locale et bio disponibles à
                            proximité directe.
                        </p>
                    </div>
                    <div
                        class="bg-white p-8 rounded-[20px] shadow-sm border border-gray-100 flex flex-col items-start"
                    >
                        <img
                            src="/vector_convivialite_festival.svg"
                            alt="Confort"
                            class="w-10 h-10 mb-4 text-[var(--color-primary)]"
                        />
                        <h3
                            class="text-xl font-black text-black font-title uppercase tracking-wide mb-3"
                        >
                            Zones de repos
                        </h3>
                        <p class="text-gray-600 font-medium leading-relaxed">
                            Espaces ombragés et aménagés pour se détendre entre
                            les concerts.
                        </p>
                    </div>
                </div>
            </section>

            <section
                class="bg-[var(--color-bg-warm)] rounded-[30px] p-8 md:p-12 shadow-inner"
            >
                <div
                    class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12"
                >
                    <div>
                        <h2
                            class="text-3xl md:text-4xl font-black text-black font-title uppercase tracking-tight mb-2"
                        >
                            Artistes à cette scène
                        </h2>
                        <p class="text-gray-600 font-medium text-lg">
                            Découvrez les performances programmées à {scene.nom}
                        </p>
                    </div>
                    <a
                        href="/programme"
                        class="inline-flex justify-center items-center px-10 py-4 bg-[var(--color-primary)] text-white font-black uppercase tracking-wider rounded-full hover:brightness-110 transition-all shadow-md text-center whitespace-nowrap"
                    >
                        Voir tout le programme
                    </a>
                </div>

                {
                    artistes.length > 0 ? (
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            {artistes.map((artiste) => (
                                <article class="bg-white rounded-[20px] p-6 shadow-sm border border-gray-100 flex flex-col sm:flex-row gap-6 items-center group hover:shadow-md transition-shadow">
                                    <div class="w-full sm:w-1/3 h-[150px] rounded-[15px] overflow-hidden shrink-0 relative">
                                        <img
                                            src={
                                                artiste.image_principale
                                                    ? `http://127.0.0.1:8090/api/files/${artiste.collectionId}/${artiste.id}/${artiste.image_principale}`
                                                    : "/hero_artist.avif"
                                            }
                                            alt={artiste.nom}
                                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                        />
                                    </div>
                                    <div class="w-full sm:w-2/3 flex flex-col">
                                        <h3 class="text-2xl font-black text-black font-title uppercase mb-3">
                                            {artiste.nom}
                                        </h3>
                                        <div class="flex items-center gap-2 text-gray-600 font-medium mb-4">
                                            <img
                                                src="/vector_date_card_artist.svg"
                                                alt="Date"
                                                class="w-5 h-5 text-[var(--color-primary)]"
                                            />
                                            <span>
                                                {formatteDate(
                                                    artiste.date_passage,
                                                )}
                                            </span>
                                        </div>
                                        <a
                                            href={`/artistes/${artiste.id}`}
                                            class="inline-block mt-auto text-[var(--color-primary)] font-bold uppercase tracking-wider text-sm hover:text-black transition-colors"
                                        >
                                            En savoir plus →
                                        </a>
                                    </div>
                                </article>
                            ))}
                        </div>
                    ) : (
                        <div class="bg-white rounded-[20px] p-12 text-center border border-gray-100">
                            <p class="text-xl text-gray-500 font-medium">
                                Aucun artiste n'est encore programmé sur cette
                                scène.
                            </p>
                        </div>
                    )
                }
            </section>
            <br><br>
        </div>
    </main>
</Layout>
