---
import { addOrUpdate } from "../../backend/backend.mjs";

let message = "";

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const idSaisi = formData.get("id_scene");
        const nomSaisi = formData.get("nom_scene");

        const data = { nom: String(nomSaisi) };
        if (idSaisi) {
            Object.assign(data, { id: String(idSaisi) });
        }

        const resultat = await addOrUpdate("scenes", data);

        if (idSaisi) {
            message = `✅ Modification réussie : La scène porte maintenant le nom "${resultat.nom}".`;
        } else {
            message = `✅ Création réussie : La scène "${resultat.nom}" a été ajoutée (ID: ${resultat.id}).`;
        }
    } catch (e) {
        if (e instanceof Error) {
            message = `❌ Erreur lors de l'envoi : ${e.message}`;
        } else {
            message = "❌ Une erreur inconnue est survenue.";
        }
    }
}
---

<html lang="fr">
    <head>
        <meta charset="utf-8" />
        <title>Gérer les scènes</title>
    </head>
    <body
        style="font-family: Arial, sans-serif; padding: 2rem; max-width: 500px;"
    >
        <h1>Ajouter ou Modifier une scène</h1>
        <p>Depuis le front, directement dans la base de données !</p>

        {
            message && (
                <div style="padding: 1rem; margin-bottom: 1rem; background-color: #f0fdf4; border: 1px solid #16a34a; border-radius: 5px;">
                    {message}
                </div>
            )
        }

        <form
            method="POST"
            style="display: flex; flex-direction: column; gap: 1rem; background: #f9f9f9; padding: 1.5rem; border-radius: 8px;"
        >
            <div>
                <label
                    for="nom_scene"
                    style="font-weight: bold; display: block;"
                    >Nom de la scène * :</label
                >
                <input
                    type="text"
                    id="nom_scene"
                    name="nom_scene"
                    required
                    placeholder="Ex: Scène du Lac"
                    style="width: 100%; padding: 8px; margin-top: 5px;"
                />
            </div>

            <div>
                <label for="id_scene" style="font-weight: bold; display: block;"
                    >ID de la scène (Facultatif) :</label
                >
                <p
                    style="font-size: 0.85rem; color: #666; margin: 2px 0 5px 0;"
                >
                    Laissez vide pour créer. Remplissez pour modifier une scène
                    existante.
                </p>
                <input
                    type="text"
                    id="id_scene"
                    name="id_scene"
                    placeholder="Ex: byszdeelhfzz70m"
                    style="width: 100%; padding: 8px;"
                />
            </div>

            <button
                type="submit"
                style="padding: 10px; background-color: #2563eb; color: white; border: none; border-radius: 5px; cursor: pointer; font-size: 1rem;"
            >
                Envoyer à PocketBase
            </button>
        </form>
    </body>
</html>
