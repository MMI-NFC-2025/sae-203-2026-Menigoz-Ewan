---
// Le code serveur est supprimé pour éviter l'erreur Content-Type
---

<html lang="fr">
    <head>
        <meta charset="utf-8" />
        <title>Gérer les scènes</title>
    </head>
    <body
        style="font-family: Arial, sans-serif; padding: 2rem; max-width: 500px;"
    >
        <h1>Ajouter ou Modifier une scène</h1>
        <p>Depuis le front, directement dans la base de données !</p>

        <div
            id="messageBox"
            style="display: none; padding: 1rem; margin-bottom: 1rem; border-radius: 5px;"
        >
        </div>

        <form
            id="sceneForm"
            style="display: flex; flex-direction: column; gap: 1rem; background: #f9f9f9; padding: 1.5rem; border-radius: 8px;"
        >
            <div>
                <label
                    for="nom_scene"
                    style="font-weight: bold; display: block;"
                >
                    Nom de la scène * :
                </label>
                <input
                    type="text"
                    id="nom_scene"
                    name="nom_scene"
                    required
                    placeholder="Ex: Scène du Lac"
                    style="width: 100%; padding: 8px; margin-top: 5px;"
                />
            </div>

            <div>
                <label
                    for="id_scene"
                    style="font-weight: bold; display: block;"
                >
                    ID de la scène (Facultatif) :
                </label>
                <p
                    style="font-size: 0.85rem; color: #666; margin: 2px 0 5px 0;"
                >
                    Laissez vide pour créer. Remplissez pour modifier une scène
                    existante.
                </p>
                <input
                    type="text"
                    id="id_scene"
                    name="id_scene"
                    placeholder="Ex: byszdeelhfzz70m"
                    style="width: 100%; padding: 8px;"
                />
            </div>

            <button
                type="submit"
                id="submitBtn"
                style="padding: 10px; background-color: #2563eb; color: white; border: none; border-radius: 5px; cursor: pointer; font-size: 1rem;"
            >
                Envoyer à PocketBase
            </button>
        </form>

        <script>
            import PocketBase from "pocketbase";

            // Initialisation de PocketBase (vérifie bien l'URL si elle est différente)
            const pb = new PocketBase("http://127.0.0.1:8090");

            const sceneForm = document.getElementById(
                "sceneForm",
            ) as HTMLFormElement;
            const messageBox = document.getElementById("messageBox");
            const submitBtn = document.getElementById("submitBtn");

            sceneForm?.addEventListener("submit", async (e) => {
                e.preventDefault(); // Empêche le rechargement de la page

                if (messageBox) messageBox.style.display = "none";
                if (submitBtn) submitBtn.textContent = "Envoi en cours...";

                const nomSaisi = (
                    document.getElementById("nom_scene") as HTMLInputElement
                ).value;
                const idSaisi = (
                    document.getElementById("id_scene") as HTMLInputElement
                ).value;

                try {
                    if (idSaisi) {
                        // Modification si l'ID est fourni
                        const record = await pb
                            .collection("scenes")
                            .update(idSaisi, {
                                nom: nomSaisi,
                            });
                        if (messageBox) {
                            messageBox.textContent = `✅ Modification réussie : La scène porte maintenant le nom "${record.nom}".`;
                            messageBox.style.backgroundColor = "#f0fdf4";
                            messageBox.style.border = "1px solid #16a34a";
                            messageBox.style.color = "black";
                            messageBox.style.display = "block";
                        }
                    } else {
                        // Création si pas d'ID
                        const record = await pb.collection("scenes").create({
                            nom: nomSaisi,
                        });
                        if (messageBox) {
                            messageBox.textContent = `✅ Création réussie : La scène "${record.nom}" a été ajoutée.`;
                            messageBox.style.backgroundColor = "#f0fdf4";
                            messageBox.style.border = "1px solid #16a34a";
                            messageBox.style.color = "black";
                            messageBox.style.display = "block";
                        }
                        sceneForm.reset(); // Vide le formulaire après création
                    }
                } catch (error) {
                    console.error("Erreur avec PocketBase:", error);
                    if (messageBox) {
                        messageBox.textContent =
                            "❌ Erreur lors de l'opération. (Vérifiez l'ID ou les permissions API)";
                        messageBox.style.backgroundColor = "#fef2f2";
                        messageBox.style.border = "1px solid #dc2626";
                        messageBox.style.color = "#991b1b";
                        messageBox.style.display = "block";
                    }
                } finally {
                    if (submitBtn)
                        submitBtn.textContent = "Envoyer à PocketBase";
                }
            });
        </script>
    </body>
</html>
