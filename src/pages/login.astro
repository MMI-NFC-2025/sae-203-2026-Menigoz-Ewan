---
import { login, logout, pb } from "../../backend/backend.mjs";

let message = "";

if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "login") {
        const email = String(formData.get("email"));
        const password = String(formData.get("password"));

        const res = await login(email, password);
        if (res.success) {
            message = `Bonjour ${res.record.username || res.record.email}, vous êtes connecté !`;
        } else {
            message = "Identifiants incorrects.";
        }
    }

    if (action === "logout") {
        logout();
        message = "Vous avez été déconnecté.";
    }
}

const isConnected = pb.authStore.isValid;
---

<html lang="fr">
    <head>
        <meta charset="utf-8" />
        <title>Connexion</title>
    </head>
    <body style="font-family: sans-serif; padding: 2rem; max-width: 400px;">
        <h1>Espace Client</h1>

        {
            message && (
                <div style="padding: 1rem; margin-bottom: 1rem; background: #f0f0f0; border-radius: 5px;">
                    {message}
                </div>
            )
        }

        {
            !isConnected ? (
                <form
                    method="POST"
                    style="display: flex; flex-direction: column; gap: 1rem;"
                >
                    <input type="hidden" name="action" value="login" />

                    <div>
                        <label for="email" style="display: block;">
                            Email :
                        </label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            style="width: 100%; padding: 8px;"
                        />
                    </div>

                    <div>
                        <label for="password" style="display: block;">
                            Mot de passe :
                        </label>
                        <input
                            type="password"
                            id="password"
                            name="password"
                            required
                            style="width: 100%; padding: 8px;"
                        />
                    </div>

                    <button
                        type="submit"
                        style="padding: 10px; background: #2563eb; color: white; border: none; border-radius: 5px; cursor: pointer;"
                    >
                        Se connecter
                    </button>
                </form>
            ) : (
                <form method="POST">
                    <input type="hidden" name="action" value="logout" />
                    <p>Vous êtes actuellement en ligne.</p>
                    <button
                        type="submit"
                        style="padding: 10px; background: #dc2626; color: white; border: none; border-radius: 5px; cursor: pointer;"
                    >
                        Se déconnecter
                    </button>
                </form>
            )
        }
    </body>
</html>
