---
// Plus besoin de code serveur compliqué ici !
---

<html lang="fr">
    <head>
        <meta charset="utf-8" />
        <title>Connexion</title>
    </head>
    <body style="font-family: sans-serif; padding: 2rem; max-width: 400px;">
        <h1>Espace Client</h1>

        <div
            id="messageBox"
            style="display: none; padding: 1rem; margin-bottom: 1rem; border-radius: 5px;"
        >
        </div>

        <form
            id="loginForm"
            style="display: flex; flex-direction: column; gap: 1rem;"
        >
            <div>
                <label
                    for="email"
                    style="display: block; font-weight: bold; margin-bottom: 5px;"
                    >Email :</label
                >
                <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px;"
                />
            </div>

            <div>
                <label
                    for="password"
                    style="display: block; font-weight: bold; margin-bottom: 5px;"
                    >Mot de passe :</label
                >
                <input
                    type="password"
                    id="password"
                    name="password"
                    required
                    style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px;"
                />
            </div>

            <button
                type="submit"
                id="submitBtn"
                style="padding: 12px; background: #2563eb; color: white; border: none; border-radius: 5px; cursor: pointer; font-weight: bold;"
            >
                Se connecter
            </button>
        </form>

        <div id="logoutSection" style="display: none;">
            <p style="margin-bottom: 15px; font-weight: bold;">
                Vous êtes actuellement en ligne.
            </p>
            <button
                id="logoutBtn"
                style="padding: 12px; background: #dc2626; color: white; border: none; border-radius: 5px; cursor: pointer; font-weight: bold;"
            >
                Se déconnecter
            </button>
        </div>

        <script>
            import PocketBase from "pocketbase";
            const pb = new PocketBase("http://127.0.0.1:8090");

            const loginForm = document.getElementById("loginForm");
            const logoutSection = document.getElementById("logoutSection");
            const logoutBtn = document.getElementById("logoutBtn");
            const messageBox = document.getElementById("messageBox");
            const submitBtn = document.getElementById("submitBtn");

            // Fonction pour mettre à jour l'affichage selon si on est connecté ou non
            function updateUI() {
                if (pb.authStore.isValid) {
                    // Utilisateur connecté
                    loginForm.style.display = "none";
                    logoutSection.style.display = "block";
                    const user = pb.authStore.model;

                    messageBox.style.display = "block";
                    messageBox.style.background = "#dcfce7"; // Vert clair
                    messageBox.style.color = "#166534"; // Vert foncé
                    messageBox.textContent = `Bonjour ${user.name || user.username || user.email}, vous êtes connecté !`;
                } else {
                    // Utilisateur déconnecté
                    loginForm.style.display = "flex";
                    logoutSection.style.display = "none";
                }
            }

            // Vérifier l'état au chargement de la page
            updateUI();

            // Gérer la connexion
            loginForm?.addEventListener("submit", async (e) => {
                e.preventDefault(); // Empêche la page de recharger !

                messageBox.style.display = "none";
                submitBtn.textContent = "Connexion...";

                const email = document.getElementById("email").value;
                const password = document.getElementById("password").value;

                try {
                    // On demande à PocketBase de nous connecter
                    await pb
                        .collection("users")
                        .authWithPassword(email, password);
                    updateUI(); // On met à jour l'écran
                } catch (error) {
                    // Si l'email ou le mot de passe est faux
                    messageBox.style.display = "block";
                    messageBox.style.background = "#fee2e2"; // Rouge clair
                    messageBox.style.color = "#991b1b"; // Rouge foncé
                    messageBox.textContent =
                        "Erreur : Identifiants incorrects.";
                    console.error("Erreur de connexion :", error);
                } finally {
                    submitBtn.textContent = "Se connecter";
                }
            });

            // Gérer la déconnexion
            logoutBtn?.addEventListener("click", () => {
                pb.authStore.clear(); // Supprime la session

                messageBox.style.display = "block";
                messageBox.style.background = "#f0f0f0";
                messageBox.style.color = "#333";
                messageBox.textContent = "Vous avez été déconnecté.";

                updateUI(); // On remet le formulaire
                loginForm.reset(); // On vide les champs
            });
        </script>
    </body>
</html>
