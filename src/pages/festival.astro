---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <main class="main">
        <section class="page-header">
            <video class="page-header__video" autoplay muted loop playsinline>
                <source src="/video_festival.mp4" type="video/mp4" />
            </video>
            <div class="page-header__content">
                <h1 class="page-header__title">Le Festival</h1>
                <p class="page-header__subtitle">
                    Un festival gratuit, écoresponsable et convivial qui fait
                    vibrer Montbéliard depuis 2018
                </p>
            </div>
        </section>

        <section class="festival-section">
            <div class="festival-section__header">
                <span class="festival-section__icon">
                    <img
                        src="/vector_history_festival.svg"
                        alt="Icône Histoire"
                    />
                </span>
                <h2 class="festival-section__title">Notre histoire</h2>
            </div>

            <div class="festival-section__content">
                <p>
                    Né en 2018 de la passion d'un collectif de musiciens et
                    d'amoureux de la culture, La Fanfa'Comtoise est devenu un
                    rendez-vous incontournable pour les mélomanes. De la musique
                    au jazz, de musiques de rue et de fanfares, le festival
                    célèbre la richesse musicale de notre région à Montbéliard.
                </p>
                <p>
                    Année après année, grâce à un festival accessible à tous,
                    gratuit, qui célèbre la richesse musicale de notre région
                    tout en respectant nos valeurs écologiques. Chaque année,
                    nous accueillons des milliers de festivaliers dans le
                    magnifique cadre du centre-ville historique de Montbéliard.
                </p>
            </div>

            <div class="festival-section__stats">
                <article class="stat-card">
                    <span class="stat-card__number">7<sup>e</sup></span>
                    <p class="stat-card__label">Édition en 2025</p>
                </article>

                <article class="stat-card">
                    <span class="stat-card__number">10k+</span>
                    <p class="stat-card__label">Festivaliers en 2024</p>
                </article>

                <article class="stat-card">
                    <span class="stat-card__number">30+</span>
                    <p class="stat-card__label">Artistes depuis 2018</p>
                </article>
            </div>
        </section>

        <section class="festival-section">
            <div class="festival-section__header">
                <span class="festival-section__icon">
                    <img src="/vector_team_festival.svg" alt="Icône Équipe" />
                </span>
                <h2 class="festival-section__title">L'équipe</h2>
            </div>

            <p class="festival-section__intro">
                La Fanfa'Comtoise, c'est avant tout une équipe qui œuvre toute
                l'année pour vous offrir un festival unique et de qualité.
            </p>

            <div class="team-groups">
                <div class="team-group-card">
                    <h3 class="team-group__title">Équipes organisatrice</h3>
                    <ul class="team-group__list">
                        <li>Direction & pilotage</li>
                        <li>Communication & marketing</li>
                        <li>Logistique & production</li>
                        <li>Coordination délégués</li>
                        <li>Relations partenaires</li>
                    </ul>
                </div>

                <div class="team-group-card">
                    <h3 class="team-group__title">Équipes techniques</h3>
                    <ul class="team-group__list">
                        <li>Régie son & lumière</li>
                        <li>Montage & démontage</li>
                        <li>Accueil artistes</li>
                        <li>Sécurité & premiers secours</li>
                        <li>Décoration & aménagement</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="join-us">
            <div class="join-us__card">
                <div class="join-us__content">
                    <h3 class="join-us__title">Rejoignez-nous !</h3>
                    <p class="join-us__text">
                        Vous souhaitez participer à l'aventure ? Contactez-nous
                        pour découvrir les opportunités de bénévolat et
                        d'engagement au sein de notre équipe.
                    </p>
                    <a href="/contact" class="join-us__link">Nous contacter</a>
                </div>
            </div>
        </section>

        <section class="festival-section">
            <div class="festival-section__header">
                <span class="festival-section__icon">
                    <img
                        src="/vector_valors_festival.svg"
                        alt="Icône Valeurs"
                    />
                </span>
                <h2 class="festival-section__title">Nos valeurs</h2>
            </div>

            <div class="values-grid">
                <article class="value-card">
                    <span class="value-card__icon"
                        ><img src="/vector_eco_festival.svg" alt="éco" /></span
                    >
                    <h3 class="value-card__title">Écoresponsabilité</h3>
                    <p class="value-card__description">
                        Réduction des déchets, utilisation de matériaux
                        durables, billets zéros. Nous nous engageons pour un
                        festival à impact environnemental minimal.
                    </p>
                </article>

                <article class="value-card">
                    <span class="value-card__icon"
                        ><img
                            src="/vector_accessibility_festival.svg"
                            alt="accessibilité"
                        /></span
                    >
                    <h3 class="value-card__title">Accessibilité</h3>
                    <p class="value-card__description">
                        Un festival gratuit et ouvert à tous, avec des espaces
                        accessibles aux personnes en situation de handicap. Nos
                        programmes priorisent l'inclusion.
                    </p>
                </article>

                <article class="value-card">
                    <span class="value-card__icon"
                        ><img
                            src="/vector_music_festival.svg"
                            alt="musique"
                        /></span
                    >
                    <h3 class="value-card__title">
                        Soutien aux artistes locaux
                    </h3>
                    <p class="value-card__description">
                        Promotion des talents régionaux du jazz, fanfares et
                        musiques de rue. Nous valorisons le patrimoine musical
                        de notre région.
                    </p>
                </article>

                <article class="value-card">
                    <span class="value-card__icon"
                        ><img
                            src="/vector_convivialite_festival.svg"
                            alt="convivialité"
                        /></span
                    >
                    <h3 class="value-card__title">Convivialité</h3>
                    <p class="value-card__description">
                        Un esprit de partage et d'échanges dans une atmosphère
                        chaleureuse et bienveillante pour tous les publics.
                    </p>
                </article>
            </div>
        </section>

        <section class="edition-banner">
            <div class="edition-card">
                <h2 class="edition-card__title">
                    Édition 2025 : "Retour aux sources"
                </h2>
                <p class="edition-card__description">
                    Pour cette édition, nous revenons à l'essence même de La
                    Fanfa'Comtoise : célébrer l'énergie des rues, les traditions
                    musicales régionales et la passion des musiciens qui
                    façonnent son âme.
                </p>
                <p class="edition-card__description">
                    Un programme riche en émotions, avec des artistes qui
                    reprendront les valeurs fondatrices de notre festival :
                    authenticité, convivialité et engagement pour une culture
                    durable et accessible.
                </p>
            </div>
        </section>
    </main>
</Layout>

<style>
    .page-header {
        position: relative;
        height: 60vh;
        min-height: 400px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        overflow: hidden;
    }

    .page-header__video {
        position: absolute;
        top: 50%;
        left: 50%;
        min-width: 100%;
        min-height: 100%;
        transform: translate(-50%, -50%);
        z-index: -1;
        object-fit: cover;
    }

    .page-header__content {
        position: relative;
        z-index: 1;
        max-width: 800px;
        padding: 0 2rem;
    }

    .page-header__title {
        font-size: 4rem;
        color: #111111;
        margin-bottom: 1rem;
        font-weight: 800;
    }

    .page-header__subtitle {
        font-size: 1.25rem;
        color: #111111;
        font-weight: 500;
        line-height: 1.5;
    }

    .festival-section {
        max-width: 1100px;
        margin: 5rem auto;
        padding: 0 2rem;
    }

    .festival-section__header {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        margin-bottom: 2.5rem;
    }

    .festival-section__icon img {
        width: 35px;
        height: 35px;
        object-fit: contain;
    }

    .festival-section__title {
        font-size: 2.5rem;
        font-weight: 800;
    }

    .festival-section__content p {
        margin-bottom: 1.5rem;
        line-height: 1.8;
        font-size: 1.1rem;
        color: #444;
    }

    .festival-section__stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-top: 4rem;
    }

    .stat-card {
        background: white;
        padding: 3rem 2rem;
        border-radius: 15px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }

    .stat-card__number {
        display: block;
        font-size: 3rem;
        font-weight: 900;
        color: var(--color-orange);
        margin-bottom: 0.5rem;
    }

    .stat-card__label {
        font-weight: 600;
        color: #666;
    }

    .team-groups {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem;
        margin-top: 2rem;
    }

    .team-group-card {
        background: white;
        padding: 3rem;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }

    .team-group__title {
        font-size: 1.5rem;
        margin-bottom: 2rem;
        color: var(--color-orange);
        font-weight: 800;
    }

    .team-group__list {
        list-style: none;
        padding: 0;
    }

    .team-group__list li {
        padding: 0.8rem 0;
        border-bottom: 1px solid #f5f5f5;
        color: #444;
        font-weight: 500;
    }

    .join-us {
        max-width: 1100px;
        margin: 0 auto;
        padding: 4rem 2rem;
        text-align: center;
    }

    .join-us__card {
        border: 2px solid var(--color-orange);
        border-radius: 20px;
        padding: 5rem 3rem;
        background-color: transparent;
    }

    .join-us__content {
        max-width: 800px;
        margin: 0 auto;
    }

    .join-us__title {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
    }

    .join-us__text {
        font-size: 1.2rem;
        color: #444;
        margin-bottom: 2.5rem;
        line-height: 1.6;
    }

    .join-us__link {
        display: inline-block;
        background-color: var(--color-orange);
        color: white;
        padding: 1rem 3rem;
        border-radius: 999px;
        font-weight: 800;
        font-size: 1.1rem;
        transition: transform 0.2s ease;
        box-shadow: 0 4px 15px rgba(242, 156, 31, 0.4);
    }

    .join-us__link:hover {
        transform: translateY(-3px);
    }

    .values-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem;
    }

    .value-card {
        background: white;
        padding: 3rem;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }

    .value-card__icon img {
        width: 45px;
        height: 45px;
        margin-bottom: 1.5rem;
        object-fit: contain;
    }

    .value-card__title {
        font-size: 1.4rem;
        margin-bottom: 1rem;
        font-weight: 800;
    }

    .value-card__description {
        line-height: 1.6;
        color: #555;
    }

    .edition-banner {
        padding: 5rem 2rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .edition-card {
        border: 2px solid var(--color-orange);
        border-radius: 20px;
        color: #111;
        padding: 5rem 4rem;
        text-align: center;
        background-color: white;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }

    .edition-card__title {
        color: #111;
        font-size: 3rem;
        margin-bottom: 2.5rem;
        font-weight: 900;
    }

    .edition-card__description {
        font-size: 1.2rem;
        line-height: 1.8;
        margin-bottom: 2rem;
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
        color: #444;
    }

    @media (max-width: 992px) {
        .team-groups,
        .values-grid {
            grid-template-columns: 1fr;
        }
        .festival-section__stats {
            grid-template-columns: 1fr;
        }
        .page-header__title {
            font-size: 3rem;
        }
        .join-us__card,
        .edition-card {
            padding: 3rem 1.5rem;
        }
        .edition-card__title {
            font-size: 2.2rem;
        }
    }
</style>
