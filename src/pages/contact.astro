---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact - La Fanfa'Comtoise">
    <main class="w-full overflow-x-hidden bg-[var(--color-bg-light)]">
        <section
            class="bg-[#F6F3E9] py-24 md:py-32 px-6 flex flex-col items-center justify-center text-center"
        >
            <h1
                class="text-5xl md:text-[3.5rem] font-black text-[#111] mb-6 leading-tight font-title uppercase tracking-tighter"
            >
                Contactez-nous
            </h1>
            <p
                class="text-xl text-[#444] max-w-[750px] mx-auto leading-relaxed font-medium"
            >
                Une question, une suggestion ou envie de devenir partenaire ?
                N'hésitez pas à nous écrire !
            </p>
        </section>

        <section class="max-w-[1250px] mx-auto my-20 px-6">
            <h2
                class="text-4xl font-black text-center mb-14 font-title uppercase tracking-tight"
            >
                Nos coordonnées
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
                <div
                    class="bg-white p-10 md:p-14 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] flex flex-col border border-gray-100 items-center text-center"
                >
                    <div
                        class="w-[50px] h-[50px] flex-shrink-0 flex items-center justify-center bg-[var(--color-primary)] rounded-full mb-6 shadow-sm overflow-hidden p-0"
                    >
                        <img
                            src="/vector_mail_contact.svg"
                            alt="Email"
                            class="w-full h-full object-cover"
                        />
                    </div>
                    <h3
                        class="text-2xl font-black font-title uppercase text-black mb-4"
                    >
                        Email
                    </h3>
                    <p
                        class="text-[1.1rem] leading-relaxed text-[#444] font-medium"
                    >
                        <a
                            href="mailto:contact@fanfacomtoise.fr"
                            class="font-bold text-[var(--color-primary)] hover:underline transition-all"
                            >contact@fanfacomtoise.fr</a
                        >
                    </p>
                </div>

                <div
                    class="bg-white p-10 md:p-14 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] flex flex-col border border-gray-100 items-center text-center"
                >
                    <div
                        class="w-[50px] h-[50px] flex-shrink-0 flex items-center justify-center bg-[var(--color-primary)] rounded-full mb-6 shadow-sm overflow-hidden p-0"
                    >
                        <img
                            src="/vector_phone_contact.svg"
                            alt="Téléphone"
                            class="w-full h-full object-cover"
                        />
                    </div>
                    <h3
                        class="text-2xl font-black font-title uppercase text-black mb-4"
                    >
                        Téléphone
                    </h3>
                    <div
                        class="text-[1.1rem] leading-relaxed text-[#444] font-medium"
                    >
                        <strong class="block text-lg">03 81 12 34 56</strong>
                        <span class="text-sm text-[#888]"
                            >Du lundi au vendredi, 9h-18h</span
                        >
                    </div>
                </div>

                <div
                    class="bg-white p-10 md:p-14 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] flex flex-col border border-gray-100 items-center text-center"
                >
                    <div
                        class="w-[50px] h-[50px] flex-shrink-0 flex items-center justify-center bg-[var(--color-primary)] rounded-full mb-6 shadow-sm overflow-hidden p-0"
                    >
                        <img
                            src="/vector_location_contact.svg"
                            alt="Adresse"
                            class="w-full h-full object-cover"
                        />
                    </div>
                    <h3
                        class="text-2xl font-black font-title uppercase text-black mb-4"
                    >
                        Adresse
                    </h3>
                    <p
                        class="text-[1.1rem] leading-relaxed text-[#444] font-medium"
                    >
                        Association La Fanfa'Comtoise<br />
                        Place Saint-Martin<br />
                        25200 Montbéliard<br />
                        France
                    </p>
                </div>
            </div>
        </section>

        <section class="max-w-[1250px] mx-auto mb-20 px-6">
            <h2
                class="text-4xl font-black text-center mb-14 font-title uppercase tracking-tight"
            >
                Nos réseaux
            </h2>
            <div
                class="grid grid-cols-1 md:grid-cols-2 gap-10 max-w-[850px] mx-auto justify-center"
            >
                <a
                    href="https://facebook.com"
                    target="_blank"
                    class="group bg-white p-10 md:p-14 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] flex flex-col items-center text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-xl border border-gray-100"
                >
                    <div
                        class="w-[50px] h-[50px] flex-shrink-0 flex items-center justify-center bg-[#b8d432] rounded-full mb-6 shadow-sm overflow-hidden p-0"
                    >
                        <img
                            src="/vector_facebook.svg"
                            alt="Facebook"
                            class="w-full h-full object-cover"
                        />
                    </div>
                    <h3
                        class="text-2xl font-black font-title uppercase text-black group-hover:text-[#b8d432] transition-colors mb-2"
                    >
                        Facebook
                    </h3>
                    <p
                        class="text-[1.1rem] leading-relaxed text-[#444] font-medium"
                    >
                        Suivez nos actualités en direct
                    </p>
                </a>

                <a
                    href="https://instagram.com"
                    target="_blank"
                    class="group bg-white p-10 md:p-14 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] flex flex-col items-center text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-xl border border-gray-100"
                >
                    <div
                        class="w-[50px] h-[50px] flex-shrink-0 flex items-center justify-center bg-[#b8d432] rounded-full mb-6 shadow-sm overflow-hidden p-0"
                    >
                        <img
                            src="/vector_instagram.svg"
                            alt="Instagram"
                            class="w-full h-full object-cover"
                        />
                    </div>
                    <h3
                        class="text-2xl font-black font-title uppercase text-black group-hover:text-[#b8d432] transition-colors mb-2"
                    >
                        Instagram
                    </h3>
                    <p
                        class="text-[1.1rem] leading-relaxed text-[#444] font-medium"
                    >
                        Découvrez les coulisses en images
                    </p>
                </a>
            </div>
        </section>

        <section
            class="bg-[#F29C1F] text-white py-20 my-24 px-6 text-center w-full shadow-inner"
        >
            <div class="max-w-[900px] mx-auto">
                <h2
                    class="text-5xl md:text-[3rem] font-black mb-6 uppercase tracking-tight font-title leading-none"
                >
                    Rejoignez l'équipe
                </h2>
                <p class="text-xl leading-relaxed font-medium">
                    Vous souhaitez devenir bénévole pour le festival ?
                    Contactez-nous en précisant votre disponibilité dans le
                    formulaire ci-dessous.
                </p>
            </div>
        </section>

        <section class="max-w-[900px] mx-auto mb-28 px-6">
            <h2
                class="text-[2rem] font-black text-[#111] mb-6 text-left font-title uppercase tracking-tight"
            >
                Envoyez-nous un message
            </h2>

            <div
                id="responseMessage"
                class="hidden p-6 mb-8 rounded-xl font-bold text-lg text-center"
            >
            </div>

            <div
                class="bg-white p-8 md:p-14 rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.05)] border border-[#eee]"
            >
                <form id="contactForm" class="flex flex-col gap-6">
                    <div class="flex flex-col gap-2">
                        <label
                            for="name"
                            class="font-bold text-base text-[#111]"
                            >Nom complet <span class="text-[#F29C1F]">*</span
                            ></label
                        >
                        <input
                            type="text"
                            id="name"
                            name="nom"
                            class="w-full p-5 border border-[#ddd] rounded-lg text-base bg-white focus:ring-2 focus:ring-[#F29C1F] outline-none"
                            placeholder="Votre nom"
                            required
                        />
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="email"
                            class="font-bold text-base text-[#111]"
                            >Email <span class="text-[#F29C1F]">*</span></label
                        >
                        <input
                            type="email"
                            id="email"
                            name="email"
                            class="w-full p-5 border border-[#ddd] rounded-lg text-base bg-white focus:ring-2 focus:ring-[#F29C1F] outline-none"
                            placeholder="votre@email.fr"
                            required
                        />
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="subject"
                            class="font-bold text-base text-[#111]"
                            >Sujet <span class="text-[#F29C1F]">*</span></label
                        >
                        <input
                            type="text"
                            id="subject"
                            name="sujet"
                            class="w-full p-5 border border-[#ddd] rounded-lg text-base bg-white focus:ring-2 focus:ring-[#F29C1F] outline-none"
                            placeholder="Objet de votre message"
                            required
                        />
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="message"
                            class="font-bold text-base text-[#111]"
                            >Message <span class="text-[#F29C1F]">*</span
                            ></label
                        >
                        <textarea
                            id="message"
                            name="message"
                            rows="6"
                            class="w-full p-5 border border-[#ddd] rounded-lg text-base bg-white focus:ring-2 focus:ring-[#F29C1F] outline-none resize-y"
                            placeholder="Votre message..."
                            required></textarea>
                    </div>

                    <button
                        type="submit"
                        id="submitBtn"
                        class="w-full mt-4 bg-[#F29C1F] text-white py-5 rounded-full font-black text-xl flex items-center justify-center gap-3 transition-all hover:bg-[#e08b1a] hover:-translate-y-1 shadow-md uppercase tracking-wider"
                    >
                        <span>Envoyer le message</span>
                    </button>
                </form>
            </div>
        </section>
    </main>
</Layout>

<script>
    import PocketBase from "pocketbase";

    const contactForm = document.getElementById(
        "contactForm",
    ) as HTMLFormElement;
    const responseMessage = document.getElementById("responseMessage");
    const pb = new PocketBase("http://127.0.0.1:8090");

    contactForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        responseMessage?.classList.add("hidden");

        const formData = new FormData(contactForm);
        const data = Object.fromEntries(formData);

        try {
            await pb.collection("messages").create(data);
            if (responseMessage) {
                responseMessage.textContent =
                    "Votre message a bien été envoyé !";
                responseMessage.className =
                    "p-6 mb-8 rounded-xl font-bold text-lg bg-green-100 text-green-800 border border-green-300 text-center";
                responseMessage.classList.remove("hidden");
            }
            contactForm.reset();
        } catch (error) {
            if (responseMessage) {
                responseMessage.textContent =
                    "Erreur : Impossible d'envoyer le message.";
                responseMessage.className =
                    "p-6 mb-8 rounded-xl font-bold text-lg bg-red-100 text-red-800 border border-red-300 text-center";
                responseMessage.classList.remove("hidden");
            }
        }
    });
</script>
