---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact - La Fanfa'Comtoise">
    <main class="w-full overflow-x-hidden">
        <section
            class="bg-[#F6F3E9] py-24 md:py-32 px-6 flex flex-col items-center justify-center text-center"
        >
            <h1
                class="text-5xl md:text-[3.5rem] font-extrabold text-[#111] mb-6 leading-tight"
            >
                Contactez-nous
            </h1>
            <p
                class="text-xl text-[#444] max-w-[750px] mx-auto leading-relaxed"
            >
                Une question, une suggestion ou envie de devenir partenaire ?
                N'hésitez pas à nous écrire !
            </p>
        </section>

        <section class="max-w-[1250px] mx-auto my-20 px-6">
            <h2 class="text-4xl font-extrabold text-center mb-14">
                Nos coordonnées
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
                <div
                    class="bg-white p-10 md:p-14 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] flex flex-col"
                >
                    <div class="flex items-center gap-6 mb-6">
                        <div
                            class="w-[75px] h-[75px] flex-shrink-0 flex items-center justify-center"
                        >
                            <img
                                src="/vector_mail_contact.svg"
                                alt="Email"
                                class="w-full h-full object-contain"
                            />
                        </div>
                        <h3 class="text-2xl font-extrabold">Email</h3>
                    </div>
                    <p class="text-[1.1rem] leading-relaxed text-[#444]">
                        <a
                            href="mailto:contact@fanfacomtoise.fr"
                            class="font-bold hover:text-[#F29C1F] transition-colors"
                            >contact@fanfacomtoise.fr</a
                        >
                    </p>
                </div>

                <div
                    class="bg-white p-10 md:p-14 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] flex flex-col"
                >
                    <div class="flex items-center gap-6 mb-6">
                        <div
                            class="w-[75px] h-[75px] flex-shrink-0 flex items-center justify-center"
                        >
                            <img
                                src="/vector_phone_contact.svg"
                                alt="Téléphone"
                                class="w-full h-full object-contain"
                            />
                        </div>
                        <h3 class="text-2xl font-extrabold">Téléphone</h3>
                    </div>
                    <div class="text-[1.1rem] leading-relaxed text-[#444]">
                        <strong class="block">03 81 12 34 56</strong>
                        <span class="text-sm text-[#888]"
                            >Du lundi au vendredi, 9h-18h</span
                        >
                    </div>
                </div>

                <div
                    class="bg-white p-10 md:p-14 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] flex flex-col"
                >
                    <div class="flex items-center gap-6 mb-6">
                        <div
                            class="w-[75px] h-[75px] flex-shrink-0 flex items-center justify-center"
                        >
                            <img
                                src="/vector_location_contact.svg"
                                alt="Adresse"
                                class="w-full h-full object-contain"
                            />
                        </div>
                        <h3 class="text-2xl font-extrabold">Adresse</h3>
                    </div>
                    <p class="text-[1.1rem] leading-relaxed text-[#444]">
                        Association La Fanfa'Comtoise<br />
                        Place Saint-Martin<br />
                        25200 Montbéliard<br />
                        France
                    </p>
                </div>
            </div>
        </section>

        <section class="max-w-[1250px] mx-auto mb-20 px-6">
            <h2 class="text-4xl font-extrabold text-center mb-14">
                Nos réseaux
            </h2>
            <div
                class="grid grid-cols-1 md:grid-cols-2 gap-10 max-w-[850px] mx-auto justify-center"
            >
                <a
                    href="https://facebook.com"
                    target="_blank"
                    class="group bg-white p-10 md:p-14 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] flex flex-col transition-all duration-300 hover:-translate-y-2 hover:shadow-xl"
                >
                    <div class="flex items-center gap-6 mb-6">
                        <div
                            class="w-[75px] h-[75px] flex-shrink-0 flex items-center justify-center"
                        >
                            <img
                                src="/vector_facebook.svg"
                                alt="Facebook"
                                class="w-full h-full object-contain"
                            />
                        </div>
                        <h3 class="text-2xl font-extrabold">Facebook</h3>
                    </div>
                    <p class="text-[1.1rem] leading-relaxed text-[#444]">
                        Suivez nos actualités en direct
                    </p>
                </a>

                <a
                    href="https://instagram.com"
                    target="_blank"
                    class="group bg-white p-10 md:p-14 rounded-[20px] shadow-[0_10px_30px_rgba(0,0,0,0.05)] flex flex-col transition-all duration-300 hover:-translate-y-2 hover:shadow-xl"
                >
                    <div class="flex items-center gap-6 mb-6">
                        <div
                            class="w-[75px] h-[75px] flex-shrink-0 flex items-center justify-center"
                        >
                            <img
                                src="/vector_instagram.svg"
                                alt="Instagram"
                                class="w-full h-full object-contain"
                            />
                        </div>
                        <h3 class="text-2xl font-extrabold">Instagram</h3>
                    </div>
                    <p class="text-[1.1rem] leading-relaxed text-[#444]">
                        Découvrez les coulisses en images
                    </p>
                </a>
            </div>
        </section>

        <section
            class="bg-[#F29C1F] text-white py-20 my-24 px-6 text-center w-full"
        >
            <div class="max-w-[900px] mx-auto">
                <h2
                    class="text-5xl md:text-[3rem] font-black mb-6 uppercase tracking-tight"
                >
                    Rejoignez l'équipe
                </h2>
                <p class="text-xl leading-relaxed">
                    Vous souhaitez devenir bénévole pour le festival ?
                    Contactez-nous en précisant votre disponibilité dans le
                    formulaire ci-dessous.
                </p>
            </div>
        </section>

        <section class="max-w-[900px] mx-auto mb-28 px-6">
            <h2 class="text-[2rem] font-extrabold text-[#111] mb-6 text-left">
                Envoyez-nous un message
            </h2>
            <div
                class="bg-white p-8 md:p-14 rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.05)] border border-[#eee]"
            >
                <form class="flex flex-col gap-6">
                    <div class="flex flex-col gap-2">
                        <label
                            for="name"
                            class="font-extrabold text-base text-[#111]"
                            >Nom complet <span class="text-[#F29C1F]">*</span
                            ></label
                        >
                        <input
                            type="text"
                            id="name"
                            class="w-full p-5 border border-[#ddd] rounded-lg text-base bg-white focus:ring-2 focus:ring-[#F29C1F] outline-none"
                            placeholder="Votre nom"
                            required
                        />
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="email"
                            class="font-extrabold text-base text-[#111]"
                            >Email <span class="text-[#F29C1F]">*</span></label
                        >
                        <input
                            type="email"
                            id="email"
                            class="w-full p-5 border border-[#ddd] rounded-lg text-base bg-white focus:ring-2 focus:ring-[#F29C1F] outline-none"
                            placeholder="votre@email.fr"
                            required
                        />
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="subject"
                            class="font-extrabold text-base text-[#111]"
                            >Sujet <span class="text-[#F29C1F]">*</span></label
                        >
                        <input
                            type="text"
                            id="subject"
                            class="w-full p-5 border border-[#ddd] rounded-lg text-base bg-white focus:ring-2 focus:ring-[#F29C1F] outline-none"
                            placeholder="Sélectionnez un sujet"
                            required
                        />
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="message"
                            class="font-extrabold text-base text-[#111]"
                            >Message <span class="text-[#F29C1F]">*</span
                            ></label
                        >
                        <textarea
                            id="message"
                            rows="6"
                            class="w-full p-5 border border-[#ddd] rounded-lg text-base bg-white focus:ring-2 focus:ring-[#F29C1F] outline-none resize-y"
                            placeholder="Votre message..."
                            required></textarea>
                    </div>

                    <button
                        type="submit"
                        class="w-full mt-4 bg-[#F29C1F] text-white py-5 rounded-full font-extrabold text-xl flex items-center justify-center gap-3 transition-all hover:bg-[#e08b1a] hover:-translate-y-1"
                    >
                        <img
                            src="/vector_send_contact.svg"
                            alt="Envoyer"
                            class="w-5 h-5"
                        />
                        Envoyer le message
                    </button>
                </form>
            </div>
            <p
                class="mt-6 text-sm text-[#666] italic text-left leading-relaxed"
            >
                Les transports en commun ou en voiture nous facilitent les
                déplacements à différentes raisons à vôtre demande.
            </p>
        </section>
    </main>
</Layout>
