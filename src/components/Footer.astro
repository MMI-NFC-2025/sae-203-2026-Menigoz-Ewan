---

<footer class="footer">
    <div class="footer__container">
        <div class="footer__section">
            <h3 class="footer__title">Navigation</h3>
            <ul class="footer__list">
                <li><a href="/" class="footer__link">Accueil</a></li>
                <li>
                    <a href="/festival" class="footer__link">Le Festival</a>
                </li>
                <li><a href="/programme" class="footer__link">Programme</a></li>
                <li><a href="/artistes" class="footer__link">Artistes</a></li>
                <li>
                    <a href="/infos" class="footer__link">Infos Pratiques</a>
                </li>
                <li><a href="/contact" class="footer__link">Contact</a></li>
            </ul>
        </div>

        <div class="footer__section">
            <h3 class="footer__title">Contact</h3>
            <ul class="footer__list">
                <li>
                    <img
                        src="/vector_localisation.svg"
                        alt="Localisation"
                        class="footer__icon"
                    />
                    <span>Place Saint-Martin<br />25200 Montbéliard</span>
                </li>
                <li>
                    <img
                        src="/vector_mail.svg"
                        alt="Email"
                        class="footer__icon"
                    />
                    <a
                        href="mailto:contact@fanfacomtoise.fr"
                        class="footer__link">contact@fanfacomtoise.fr</a
                    >
                </li>
                <li>
                    <img
                        src="/vector_phone.svg"
                        alt="Téléphone"
                        class="footer__icon"
                    />
                    <a href="tel:0381123456" class="footer__link"
                        >03 81 12 34 56</a
                    >
                </li>
            </ul>
        </div>

        <div class="footer__section">
            <h3 class="footer__title">Suivez-nous</h3>
            <p class="footer__text">
                Restez informés de l'actualité du festival
            </p>
            <div class="footer__socials">
                <a href="#" class="footer__social-link">
                    <img src="/vector_facebook.svg" alt="Facebook" />
                </a>
                <a href="#" class="footer__social-link">
                    <img src="/vector_instagram.svg" alt="Instagram" />
                </a>
            </div>
        </div>
    </div>

    <div class="footer__bottom">
        <p>© 2025 La Fanfa'Comtoise - Tous droits réservés.</p>
    </div>
</footer>

<style>
    .footer {
        background-color: #ffffff;
        border-top: 4px solid #f29c1f;
        font-size: 0.95rem;
        display: flex;
        flex-direction: column;
    }

    .footer__container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 3rem 1.5rem 2rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 2.5rem;
        width: 100%;
    }

    .footer__section {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .footer__title {
        margin: 0 0 0.5rem;
        font-size: 1rem;
        font-weight: 700;
        color: #222222;
    }

    .footer__list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .footer__list li {
        margin-bottom: 0.8rem;
        color: #666666;
        display: flex;
        align-items: flex-start;
        gap: 0.8rem;
    }

    .footer__link {
        text-decoration: none;
        color: #666666;
        transition: color 0.2s ease;
    }

    .footer__link:hover {
        color: #f29c1f;
    }

    .footer__text {
        margin: 0 0 0.8rem;
        color: #666666;
    }

    .footer__icon {
        width: 20px;
        height: 20px;
        object-fit: contain;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .footer__socials {
        display: flex;
        gap: 0.8rem;
    }

    .footer__social-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease;
    }

    .footer__social-link:hover {
        transform: translateY(-2px);
    }

    .footer__social-link img {
        width: 35px;
        height: 35px;
    }

    .footer__bottom {
        background-color: #8fd26a;
        text-align: center;
        padding: 1rem 1.5rem;
        font-size: 0.85rem;
        color: #111111;
        width: 100%;
        box-sizing: border-box;
        font-weight: 500;
    }

    @media (max-width: 800px) {
        .footer__container {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .footer__list li {
            justify-content: center;
        }

        .footer__socials {
            justify-content: center;
        }
    }
</style>
