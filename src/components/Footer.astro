---

---

<footer
    class="bg-white border-t-4 border-[#F29C1F] text-[0.95rem] flex flex-col w-full"
>
    <div
        class="max-w-[1100px] mx-auto w-full px-6 pt-12 pb-8 grid grid-cols-1 md:grid-cols-3 gap-10 text-center md:text-left"
    >
        <div class="flex flex-col gap-3">
            <h3 class="text-base font-bold text-[#222] mb-2">Navigation</h3>
            <ul class="flex flex-col gap-3 m-0 p-0 list-none">
                <li>
                    <a
                        href="/"
                        class="text-[#666] hover:text-[#F29C1F] transition-colors"
                        >Accueil</a>
                </li>
                <li>
                    <a
                        href="/festival"
                        class="text-[#666] hover:text-[#F29C1F] transition-colors"
                        >Le Festival</a>
                </li>
                <li>
                    <a
                        href="/programme"
                        class="text-[#666] hover:text-[#F29C1F] transition-colors"
                        >Programme</a>
                </li>
                <li>
                    <a
                        href="/artistes"
                        class="text-[#666] hover:text-[#F29C1F] transition-colors"
                        >Artistes</a>
                </li>
                <li>
                    <a
                        href="/infos"
                        class="text-[#666] hover:text-[#F29C1F] transition-colors"
                        >Infos Pratiques</a>
                </li>
                <li>
                    <a
                        href="/contact"
                        class="text-[#666] hover:text-[#F29C1F] transition-colors"
                        >Contact</a>
                </li>
            </ul>
        </div>

        <div class="flex flex-col gap-3">
            <h3 class="text-base font-bold text-[#222] mb-2">Contact</h3>
            <ul class="flex flex-col gap-3 m-0 p-0 list-none">
                <li
                    class="flex items-start justify-center md:justify-start gap-3 text-[#666]"
                >
                    <img
                        src="/vector_localisation.svg"
                        alt="Localisation"
                        class="w-5 h-5 object-contain shrink-0 mt-[2px]"
                    />
                    <span>Place Saint-Martin<br />25200 Montbéliard</span>
                </li>
                <li
                    class="flex items-start justify-center md:justify-start gap-3 text-[#666]"
                >
                    <img
                        src="/vector_mail.svg"
                        alt="Email"
                        class="w-5 h-5 object-contain shrink-0 mt-[2px]"
                    />
                    <a
                        href="mailto:contact@fanfacomtoise.fr"
                        class="hover:text-[#F29C1F] transition-colors"
                        >contact@fanfacomtoise.fr</a
                    >
                </li>
                <li
                    class="flex items-start justify-center md:justify-start gap-3 text-[#666]"
                >
                    <img
                        src="/vector_phone.svg"
                        alt="Téléphone"
                        class="w-5 h-5 object-contain shrink-0 mt-[2px]"
                    />
                    <a
                        href="tel:0381123456"
                        class="hover:text-[#F29C1F] transition-colors"
                        >03 81 12 34 56</a
                    >
                </li>
            </ul>
        </div>

        <div class="flex flex-col gap-3 items-center md:items-start">
            <h3 class="text-base font-bold text-[#222] mb-2">Suivez-nous</h3>
            <p class="text-[#666] mb-3">
                Restez informés de l'actualité du festival
            </p>
            <div class="flex gap-3">
                <a
                    href="#"
                    class="inline-flex items-center justify-center transition-transform hover:-translate-y-1"
                >
                    <img
                        src="/vector_facebook.svg"
                        alt="Facebook"
                        class="w-9 h-9"
                    />
                </a>
                <a
                    href="#"
                    class="inline-flex items-center justify-center transition-transform hover:-translate-y-1"
                >
                    <img
                        src="/vector_instagram.svg"
                        alt="Instagram"
                        class="w-9 h-9"
                    />
                </a>
            </div>
        </div>
    </div>

    <div
        class="bg-[#8FD26A] text-center px-6 py-4 text-[0.85rem] text-[#111] font-medium w-full"
    >
        <p class="m-0">© 2026 La Fanfa'Comtoise - Tous droits réservés.</p>
    </div>
</footer>
