---

---

<header
    class="sticky top-0 left-0 w-full px-6 py-4 flex items-center justify-between bg-white border-b border-gray-200 z-[90]"
>
    <div class="flex items-center justify-between w-full">
        <a
            href="/"
            class="relative block transition-transform hover:scale-105"
            id="header-logo-link"
        >
            <div class="w-[170px] h-[80px] flex items-center justify-center">
                <img
                    id="header-logo-img"
                    src="/logo_lafanfa_comtoise.avif"
                    alt="La Fanfa'Comtoise"
                    class="w-full h-full object-contain"
                />
            </div>
        </a>

        <button
            id="menu-open-btn"
            class="relative flex flex-col justify-center items-center w-10 h-10 bg-none border-none cursor-pointer group"
            aria-expanded="false"
            aria-label="Ouvrir le menu"
        >
            <span class="block w-6 h-0.5 bg-black mb-1.5 rounded-full"></span>
            <span class="block w-6 h-0.5 bg-black mb-1.5 rounded-full"></span>
            <span class="block w-6 h-0.5 bg-black rounded-full"></span>
        </button>
    </div>
</header>

<nav
    id="main-nav"
    class="fixed inset-0 w-full h-screen bg-black/95 backdrop-blur-sm flex items-center justify-center z-[150] translate-x-full transition-transform duration-500 ease-in-out"
>
    <button
        id="menu-close-btn"
        class="absolute top-8 right-8 flex flex-col justify-center items-center w-10 h-10 bg-none border-none cursor-pointer group"
        aria-label="Fermer le menu"
    >
        <span
            class="absolute block w-8 h-0.5 bg-white rotate-45 rounded-full transition-transform hover:scale-110"
        ></span>
        <span
            class="absolute block w-8 h-0.5 bg-white -rotate-45 rounded-full transition-transform hover:scale-110"
        ></span>
    </button>

    <ul class="flex flex-col gap-8 text-center list-none p-0 m-0">
        <li>
            <a
                href="/"
                class="text-white text-2xl font-medium hover:text-[#f6b44b] transition-colors"
                >Accueil</a
            >
        </li>
        <li>
            <a
                href="/festival"
                class="text-white text-2xl font-medium hover:text-[#f6b44b] transition-colors"
                >Le Festival</a
            >
        </li>
        <li>
            <a
                href="/artistes"
                class="text-white text-2xl font-medium hover:text-[#f6b44b] transition-colors"
                >Artistes</a
            >
        </li>
        <li>
            <a
                href="/programme"
                class="text-white text-2xl font-medium hover:text-[#f6b44b] transition-colors"
                >Programme</a
            >
        </li>
        <li>
            <a
                href="/scenes"
                class="text-white text-2xl font-medium hover:text-[#f6b44b] transition-colors"
                >Scènes</a
            >
        </li>
        <li>
            <a
                href="/infos-pratiques"
                class="text-white text-2xl font-medium hover:text-[#f6b44b] transition-colors"
                >Infos Pratiques</a
            >
        </li>
        <li>
            <a
                href="/contact"
                class="text-white text-2xl font-medium hover:text-[#f6b44b] transition-colors"
                >Contact</a
            >
        </li>
        <li>
            <a
                href="/gestion"
                class="text-white text-2xl font-medium hover:text-[#f6b44b] transition-colors"
                >Gestion du festival</a
            >
        </li>
    </ul>
</nav>

<script>
    const openBtn = document.querySelector("#menu-open-btn");
    const closeBtn = document.querySelector("#menu-close-btn");
    const nav = document.querySelector("#main-nav");

    if (openBtn && closeBtn && nav) {
        openBtn.addEventListener("click", () => {
            nav.classList.remove("translate-x-full");
            nav.classList.add("translate-x-0");
            document.body.classList.add("overflow-hidden");
        });

        closeBtn.addEventListener("click", () => {
            nav.classList.remove("translate-x-0");
            nav.classList.add("translate-x-full");
            document.body.classList.remove("overflow-hidden");
        });
    }
</script>
