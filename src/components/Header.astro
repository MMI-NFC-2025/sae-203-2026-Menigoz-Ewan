---

---

<header class="header">
    <div class="header__container">
        <a href="/" class="header__link">
            <div class="header__logo">
                <img
                    src="/logo_lafanfa_comtoise.avif"
                    alt="La Fanfa'Comtoise"
                />
            </div>
        </a>

        <button
            class="header__menu-toggle"
            aria-expanded="false"
            aria-label="Ouvrir le menu"
        >
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>

    <nav class="header__nav" id="main-nav">
        <ul class="header__nav-list">
            <li><a href="/" class="header__nav-link">Accueil</a></li>
            <li>
                <a href="/festival" class="header__nav-link">Le Festival</a>
            </li>
            <li><a href="/artistes" class="header__nav-link">Artistes</a></li>
            <li><a href="/programme" class="header__nav-link">Programme</a></li>
            <li><a href="/scenes" class="header__nav-link">Scènes</a></li>
            <li>
                <a href="/infos" class="header__nav-link">Infos Pratiques</a>
            </li>
            <li><a href="/contact" class="header__nav-link">Contact</a></li>
        </ul>
    </nav>
</header>

<style>
    :root {
        --dark: #000000;
        --light: #ffffff;
        --color-primary: #f6b44b;
        --font-size-lg: 1.5rem;
    }

    .header {
        position: sticky;
        top: 0;
        left: 0;
        width: 100%;
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background-color: var(--light);
        border-bottom: 1px solid #e5e7eb;
        z-index: 100;
    }

    .header__container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
    }

    .header__link {
        display: block;
        position: relative;
        z-index: 103;
    }

    .header__logo {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 170px;
        height: 80px;
        transition: transform 0.3s ease;
        transform-origin: center;
    }

    .header__logo img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .header__menu-toggle {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        width: 40px;
        height: 40px;
        padding: 0;
        background: none;
        border: none;
        cursor: pointer;
        z-index: 103;
        position: relative;
    }

    .header__menu-toggle span {
        display: block;
        width: 24px;
        height: 2px;
        background-color: var(--dark);
        margin: 4px 0;
        transition:
            transform 0.3s ease,
            opacity 0.3s ease,
            background-color 0.3s ease;
        border-radius: 2px;
    }

    .header__menu-toggle[aria-expanded="true"] span {
        background-color: var(--light);
    }

    .header__menu-toggle[aria-expanded="true"] span:nth-child(1) {
        transform: rotate(45deg) translate(7px, 7px);
    }

    .header__menu-toggle[aria-expanded="true"] span:nth-child(2) {
        opacity: 0;
    }

    .header__menu-toggle[aria-expanded="true"] span:nth-child(3) {
        transform: rotate(-45deg) translate(7px, -7px);
    }

    .header__nav {
        position: fixed;
        top: 0;
        right: 0;
        width: 100%;
        height: 100vh;
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(5px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 101;
        transform: translateX(100%);
        transition: transform 0.3s ease;
    }

    .header__nav.is-open {
        transform: translateX(0);
    }

    .header__nav-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        text-align: center;
    }

    .header__nav-link {
        color: var(--light);
        text-decoration: none;
        font-size: var(--font-size-lg);
        font-weight: 500;
        transition: color 0.3s ease;
    }

    .header__nav-link:hover {
        color: var(--color-primary);
    }

    .header.menu-active .header__logo {
        opacity: 0;
        visibility: hidden;
    }

    .header__link {
        display: block;
        position: relative;
        z-index: 100;
    }

    .header__nav {
        position: fixed;
        top: 0;
        right: 0;
        width: 100%;
        height: 100vh;
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(5px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 101;
        transform: translateX(100%);
        transition: transform 0.3s ease;
    }

    .header__menu-toggle {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        width: 40px;
        height: 40px;
        padding: 0;
        background: none;
        border: none;
        cursor: pointer;
        z-index: 102;
        position: relative;
    }
</style>

<script>
    const toggleBtn = document.querySelector(".header__menu-toggle");
    const nav = document.querySelector(".header__nav");

    if (toggleBtn && nav) {
        toggleBtn.addEventListener("click", () => {
            const isExpanded =
                toggleBtn.getAttribute("aria-expanded") === "true";
            toggleBtn.setAttribute("aria-expanded", String(!isExpanded));
            nav.classList.toggle("is-open");
        });
    }
</script>
